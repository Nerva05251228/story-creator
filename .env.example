# Copy this file to .env and fill in local private values.
# Do not commit .env.

# Runtime
APP_ENV=local
HOST=0.0.0.0
PORT=10001
WEB_CONCURRENCY=4
PYTHONUTF8=1

# Database
DATABASE_URL=postgresql://story_creator_user@127.0.0.1:5432/story_creator_20260310
DATABASE_CONNECT_TIMEOUT=15
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_RECYCLE_SECONDS=1800

# Redis, reserved for upcoming worker/cache refactor
REDIS_URL=redis://127.0.0.1:6379/0

# Admin/auth
MASTER_PASSWORD=<set-local-master-password>
ADMIN_PANEL_PASSWORD=<set-local-admin-password>
NERVA_PASSWORD=<set-local-nerva-password>
DEFAULT_USER_PASSWORD=<set-local-default-user-password>

# Text/LLM relay
TEXT_RELAY_BASE_URL=
TEXT_RELAY_API_KEY=
TEXT_RELAY_TIMEOUT_SECONDS=120

# Image generation platform
IMAGE_PLATFORM_BASE_URL=
IMAGE_PLATFORM_API_TOKEN=
IMAGE_PLATFORM_USERNAME=story_creator
SCENE_IMAGE_API_BASE_URL=
SCENE_IMAGE_API_TOKEN=

# Backward-compatible aliases for existing local machines
# LLM_RELAY_BASE_URL=
# LLM_RELAY_API_KEY=
# IMAGE_SERVICE_API_KEY=
# BANANA_IMAGE_API_TOKEN=

# Video generation platform
VIDEO_API_BASE_URL=
VIDEO_API_TOKEN=

# Backward-compatible aliases for existing local machines
# SORA_VIDEO_API_BASE_URL=
# SORA_VIDEO_API_TOKEN=

# CDN upload
CDN_UPLOAD_URL=
CDN_UPLOAD_PATH=temp/demo

# Voiceover/TTS
VOICEOVER_TTS_API_URL=
VOICEOVER_TTS_API_TOKEN=
